generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model College {
  id            Int          @id @default(autoincrement())
  name          String       @unique
  location      String
  state         String
  city          String?
  pincode       String?
  type          String
  category      String?
  rating        Float
  totalFees     Int
  nirfRank      Int?
  established   Int?
  website       String?
  phone         String?
  accreditation String?
  imageUrl      String?
  overview      String
  createdAt     DateTime     @default(now())

  courses       Course[]
  placements    Placement[]
  reviews       Review[]
  tags          CollegeTag[]
}

model CollegeTag {
  id        Int     @id @default(autoincrement())
  collegeId Int
  tag       String

  college   College @relation(fields: [collegeId], references: [id])
}

model Course {
  id        Int     @id @default(autoincrement())
  collegeId Int
  name      String
  duration  String
  fees      Int

  college   College @relation(fields: [collegeId], references: [id])
}

model Placement {
  id             Int     @id @default(autoincrement())
  collegeId      Int
  year           Int
  averagePackage Int
  highestPackage Int
  placementRate  Float

  college        College @relation(fields: [collegeId], references: [id])
}

model Review {
  id        Int      @id @default(autoincrement())
  collegeId Int
  author    String
  rating    Float
  comment   String
  createdAt DateTime @default(now())

  college   College  @relation(fields: [collegeId], references: [id])
}
