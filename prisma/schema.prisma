generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model College {
  id         Int         @id @default(autoincrement())
  name       String
  location   String
  state      String
  type       String
  rating     Float
  totalFees  Int
  imageUrl   String?
  overview   String
  createdAt  DateTime    @default(now())

  courses    Course[]
  placements Placement[]
  reviews    Review[]
}

model Course {
  id        Int     @id @default(autoincrement())
  collegeId Int
  name      String
  duration  String
  fees      Int

  college   College @relation(fields: [collegeId], references: [id])
}

model Placement {
  id             Int     @id @default(autoincrement())
  collegeId      Int
  year           Int
  averagePackage Int
  highestPackage Int
  placementRate  Float

  college        College @relation(fields: [collegeId], references: [id])
}

model Review {
  id        Int      @id @default(autoincrement())
  collegeId Int
  author    String
  rating    Float
  comment   String
  createdAt DateTime @default(now())

  college   College  @relation(fields: [collegeId], references: [id])
}
